<Window x:Class="SakuraLikeEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SakuraLikeEditor"
        mc:Ignorable="d"
        x:Name="MainWindowRoot"
        Title="サクラエディター" Height="650" Width="980"
        MinHeight="420" MinWidth="640"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Window.Resources>
        <Style x:Key="MenuIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="2,0,2,0" />
        </Style>

        <Style x:Key="ToolBarIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToolBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="1,0,1,0" />
        </Style>

        <Style x:Key="ToolBarToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="1,0,1,0" />
        </Style>
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規(_N)" Command="{x:Static local:MainWindowCommands.NewDocument}" InputGestureText="Ctrl+N">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE710;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="開く(_O)..." Command="{x:Static local:MainWindowCommands.OpenDocument}" InputGestureText="Ctrl+O">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8E5;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="RecentFilesMenuItem" Header="最近使ったファイル(_R)" SubmenuOpened="RecentFilesMenuItem_SubmenuOpened" />
                <Separator />
                <MenuItem Header="上書き保存(_S)" Command="{x:Static local:MainWindowCommands.SaveDocument}" InputGestureText="Ctrl+S">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE74E;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="名前を付けて保存(_A)..." Command="{x:Static local:MainWindowCommands.SaveDocumentAs}" InputGestureText="Ctrl+Shift+S">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE792;" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="終了(_X)" Command="{x:Static local:MainWindowCommands.ExitApp}">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8BB;" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="編集(_E)">
                <MenuItem Header="元に戻す(_U)" Command="ApplicationCommands.Undo" InputGestureText="Ctrl+Z">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE7A7;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="やり直し(_R)" Command="ApplicationCommands.Redo" InputGestureText="Ctrl+Y">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE7A6;" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="切り取り(_T)" Command="ApplicationCommands.Cut" InputGestureText="Ctrl+X">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8C6;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="コピー(_C)" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8C8;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="貼り付け(_P)" Command="ApplicationCommands.Paste" InputGestureText="Ctrl+V">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE77F;" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="検索(_F)..." Command="{x:Static local:MainWindowCommands.Find}" InputGestureText="Ctrl+F">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE721;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="置換(_H)..." Command="{x:Static local:MainWindowCommands.Replace}" InputGestureText="Ctrl+H">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8B1;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="行へ移動(_G)..." Command="{x:Static local:MainWindowCommands.GoToLine}" InputGestureText="Ctrl+G">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8A5;" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="すべて選択(_A)" Command="ApplicationCommands.SelectAll" InputGestureText="Ctrl+A" />
            </MenuItem>

            <MenuItem Header="検索(_S)">
                <MenuItem Header="Grep検索(_G)..." Command="{x:Static local:MainWindowCommands.Grep}" InputGestureText="Ctrl+Shift+F">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE721;" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="移動(_N)">
                <MenuItem Header="ブックマーク切替(_B)" Command="{x:Static local:MainWindowCommands.ToggleBookmark}" InputGestureText="Ctrl+F2">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE734;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="次のブックマーク(_N)" Command="{x:Static local:MainWindowCommands.NextBookmark}" InputGestureText="F2">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE72A;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="前のブックマーク(_P)" Command="{x:Static local:MainWindowCommands.PrevBookmark}" InputGestureText="Shift+F2">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE72B;" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="表示(_V)">
                <MenuItem Header="折り返し(_W)"
                          Command="{x:Static local:MainWindowCommands.ToggleWordWrap}"
                          IsCheckable="True"
                          IsChecked="{Binding WordWrapEnabled, ElementName=MainWindowRoot}">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8A6;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="行番号を表示(_L)"
                          Command="{x:Static local:MainWindowCommands.ToggleLineNumbers}"
                          IsCheckable="True"
                          IsChecked="{Binding LineNumbersEnabled, ElementName=MainWindowRoot}">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8A4;" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="拡大(_I)" Command="{x:Static local:MainWindowCommands.ZoomIn}" InputGestureText="Ctrl++">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8A3;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="縮小(_O)" Command="{x:Static local:MainWindowCommands.ZoomOut}" InputGestureText="Ctrl+-">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE71F;" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="倍率リセット(_R)" Command="{x:Static local:MainWindowCommands.ZoomReset}" InputGestureText="Ctrl+0">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE8A3;" Opacity="0.6" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="CSVテーブル(_T)..." Command="{x:Static local:MainWindowCommands.CsvTable}">
                    <MenuItem.Icon>
                        <TextBlock Style="{StaticResource MenuIconTextStyle}" Text="&#xE9A1;" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="文字コード(_E)">
                <MenuItem Header="UTF-8 (BOMなし)" Command="{x:Static local:MainWindowCommands.SetEncodingUtf8NoBom}" />
                <MenuItem Header="UTF-8 (BOMあり)" Command="{x:Static local:MainWindowCommands.SetEncodingUtf8Bom}" />
                <MenuItem Header="Shift-JIS (CP932)" Command="{x:Static local:MainWindowCommands.SetEncodingShiftJis}" />
                <MenuItem Header="EUC-JP (CP51932)" Command="{x:Static local:MainWindowCommands.SetEncodingEucJp}" />
                <MenuItem Header="UTF-16 LE" Command="{x:Static local:MainWindowCommands.SetEncodingUtf16Le}" />
                <MenuItem Header="UTF-32 LE" Command="{x:Static local:MainWindowCommands.SetEncodingUtf32Le}" />
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.NewDocument}" ToolTip="新規 (Ctrl+N)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE710;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.OpenDocument}" ToolTip="開く (Ctrl+O)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE8E5;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.SaveDocument}" ToolTip="上書き保存 (Ctrl+S)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE74E;" />
                </Button>

                <Separator />

                <Button Style="{StaticResource ToolBarButtonStyle}" Command="ApplicationCommands.Undo" ToolTip="元に戻す (Ctrl+Z)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE7A7;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="ApplicationCommands.Redo" ToolTip="やり直し (Ctrl+Y)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE7A6;" />
                </Button>

                <Separator />

                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.Find}" ToolTip="検索 (Ctrl+F)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE721;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.Replace}" ToolTip="置換 (Ctrl+H)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE8B1;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.GoToLine}" ToolTip="行へ移動 (Ctrl+G)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE8A5;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.Grep}" ToolTip="Grep検索 (Ctrl+Shift+F)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE8B5;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.CsvTable}" ToolTip="CSVテーブル">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE9A1;" />
                </Button>

                <Separator />

                <ToggleButton Style="{StaticResource ToolBarToggleStyle}"
                              Command="{x:Static local:MainWindowCommands.ToggleWordWrap}"
                              IsChecked="{Binding WordWrapEnabled, ElementName=MainWindowRoot}"
                              ToolTip="折り返し">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE8A6;" />
                </ToggleButton>
                <ToggleButton Style="{StaticResource ToolBarToggleStyle}"
                              Command="{x:Static local:MainWindowCommands.ToggleLineNumbers}"
                              IsChecked="{Binding LineNumbersEnabled, ElementName=MainWindowRoot}"
                              ToolTip="行番号">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE8A4;" />
                </ToggleButton>

                <Separator />

                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.ZoomIn}" ToolTip="拡大 (Ctrl++)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE8A3;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.ZoomOut}" ToolTip="縮小 (Ctrl+-)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE71F;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.ZoomReset}" ToolTip="倍率リセット (Ctrl+0)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE8A3;" Opacity="0.6" />
                </Button>

                <Separator />

                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.ToggleBookmark}" ToolTip="ブックマーク切替 (Ctrl+F2)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE734;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.NextBookmark}" ToolTip="次のブックマーク (F2)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE72A;" />
                </Button>
                <Button Style="{StaticResource ToolBarButtonStyle}" Command="{x:Static local:MainWindowCommands.PrevBookmark}" ToolTip="前のブックマーク (Shift+F2)">
                    <TextBlock Style="{StaticResource ToolBarIconStyle}" Text="&#xE72B;" />
                </Button>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusCaretText" Text="行 1, 列 1" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusEncodingText" Text="UTF-8" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusNewlineText" Text="CRLF" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusZoomText" Text="100%" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusBookmarkText" Text="" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusAutosaveText" Text="" />
            </StatusBarItem>
        </StatusBar>

        <TabControl x:Name="DocumentsTabControl" />
    </DockPanel>
</Window>
