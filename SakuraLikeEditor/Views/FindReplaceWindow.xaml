<Window x:Class="SakuraLikeEditor.Views.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="検索と置換"
        Height="210"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2,8,6" VerticalAlignment="Center" Text="検索:" />
        <ComboBox x:Name="FindComboBox"
                  Grid.Row="0"
                  Grid.Column="1"
                  Margin="0,0,8,6"
                  MinWidth="240"
                  IsEditable="True"
                  IsTextSearchEnabled="False" />
        <Button Grid.Row="0" Grid.Column="2" Margin="0,0,0,6" Padding="10,4" Content="次を検索" Click="FindNext_Click" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,2,8,6" VerticalAlignment="Center" Text="置換後:" />
        <TextBox x:Name="ReplaceTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,6" />
        <Button Grid.Row="1" Grid.Column="2" Margin="0,0,0,6" Padding="10,4" Content="置換" Click="Replace_Click" />

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,6">
            <CheckBox x:Name="MatchCaseCheckBox" Content="大文字/小文字を区別" Margin="0,0,12,0" />
            <CheckBox x:Name="WholeWordCheckBox" Content="単語単位" />
            <CheckBox x:Name="RegexCheckBox" Content="正規表現" Margin="12,0,0,0" />
        </StackPanel>
        <Button Grid.Row="2" Grid.Column="2" Margin="0,0,0,6" Padding="10,4" Content="すべて置換" Click="ReplaceAll_Click" />

        <TextBlock x:Name="ResultTextBlock" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Foreground="#666666" />
    </Grid>
</Window>
