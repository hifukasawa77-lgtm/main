<Window x:Class="SakuraLikeEditor.Views.GrepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grep"
        Height="650"
        Width="980"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Folder:" />
            <TextBox x:Name="FolderTextBox" Grid.Column="1" MinWidth="420" />
            <Button Grid.Column="2" Margin="8,0,0,0" Padding="10,4" Content="Browse..." Click="Browse_Click" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Pattern:" />
            <TextBox x:Name="PatternTextBox" Grid.Row="0" Grid.Column="1" MinWidth="420" />
            <CheckBox x:Name="RegexCheckBox" Grid.Row="0" Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Content="Regex" />
            <CheckBox x:Name="MatchCaseCheckBox" Grid.Row="0" Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center" Content="Match case" />
            <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Margin="12,0,6,0" Text="Context:" />
            <TextBox x:Name="ContextTextBox" Grid.Row="0" Grid.Column="5" Width="60" Text="3" />

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,8,0" Text="Files:" />
            <TextBox x:Name="FilesTextBox" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Text="*.log;*.txt;*.csv;*.md;*.ini;*.json;*.xml;*.yml;*.yaml;*.cs;*.js;*.ts;*.html;*.css" />
            <Button x:Name="SearchButton" Grid.Row="1" Grid.Column="5" Margin="12,10,0,0" Padding="12,6" Content="Search" Click="Search_Click" />
        </Grid>

        <ListBox x:Name="ResultsListBox" Grid.Row="2" MouseDoubleClick="ResultsListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDDDDD" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="{Binding Header}" TextTrimming="CharacterEllipsis" />
                            <TextBox Text="{Binding Body}"
                                     Margin="0,8,0,0"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Disabled" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <DockPanel Grid.Row="3">
            <TextBlock x:Name="StatusTextBlock" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#666666" />
            <Button DockPanel.Dock="Right" Padding="12,6" Margin="8,0,0,0" Content="Close" IsCancel="True" />
        </DockPanel>
    </Grid>
</Window>

