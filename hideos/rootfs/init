#!/bin/sh
# hideOS /init — PID 1 (initramfs)
# カーネルから最初に起動されるプロセス。疑似FSのマウント→ブート画面→シェル起動を行う。

mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev 2>/dev/null
mkdir -p /dev/pts /tmp /run
mount -t devpts devpts /dev/pts
mount -t tmpfs  tmpfs  /tmp

hostname hideos
ip link set lo up 2>/dev/null

CYAN='\033[36m'
PURPLE='\033[35m'
DIM='\033[2m'
RESET='\033[0m'

clear
printf "${CYAN}"
cat /etc/motd
printf "${RESET}\n"
printf "  ${PURPLE}Welcome to hideOS — a handmade Linux distribution${RESET}\n"
printf "  ${PURPLE}ようこそ hideOS へ — 手作りのLinuxディストリビューション${RESET}\n\n"
printf "  ${DIM}Kernel : $(uname -r)${RESET}\n"
printf "  ${DIM}CPU    : $(grep -c ^processor /proc/cpuinfo) core(s)${RESET}\n"
printf "  ${DIM}Memory : $(awk '/MemTotal/{printf "%d MB", $2/1024}' /proc/meminfo)${RESET}\n"
printf "  ${DIM}Shell  : BusyBox ash  (type 'poweroff -f' to shut down / 終了は poweroff -f)${RESET}\n\n"

# シェルが終了しても再起動してPID 1が死なないようにする
while true; do
    setsid cttyhack /bin/sh -l
done
