{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "ask",
    "allow": [
      "Skill",
      "Glob",
      "Grep",
      "LS",
      "TodoWrite",
      "WebSearch",
      "Read(//home/user/main/**)",
      "Read(./**)",
      "Edit(//home/user/main/**)",
      "Edit(./**)",
      "Write(//home/user/main/**)",
      "Write(./**)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(true)",
      "Bash(false)",
      "Bash(date)",
      "Bash(which:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npx --version)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git branch -a)",
      "Bash(git branch -vv)",
      "Bash(git remote -v)",
      "Bash(git remote show:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list)",
      "Bash(git fetch)",
      "Bash(git fetch:*)",
      "Bash(openssl dgst:*)",
      "Bash(openssl base64:*)",
      "Bash(curl -s https://unpkg.com/:*)",
      "Bash(curl -sI https://unpkg.com/:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:json.schemastore.org)"
    ],
    "ask": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git tag:*)",
      "Bash(git stash:*)",
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git pull)",
      "Bash(git pull:*)",
      "Bash(git reset)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git revert:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm update:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm audit:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(ln:*)"
    ],
    "deny": [
      "Read(//home/user/main/backend/admin.db.json)",
      "Read(./backend/admin.db.json)",
      "Read(//home/user/main/backend/*.db)",
      "Read(./backend/*.db)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Read(**/id_ed25519)",
      "Read(**/id_ed25519.*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/credentials)",
      "Read(**/credentials.*)",
      "Read(**/secrets)",
      "Read(**/secrets.*)",
      "Read(**/*.secret)",
      "Read(//root/.claude/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(//home/user/main/.git/**)",
      "Edit(./.git/**)",
      "Edit(//home/user/main/.edge-test-profile/**)",
      "Edit(./.edge-test-profile/**)",
      "Edit(//home/user/main/backend/admin.db.json)",
      "Edit(./backend/admin.db.json)",
      "Edit(//root/.claude/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(//home/user/main/.git/**)",
      "Write(./.git/**)",
      "Write(//home/user/main/.edge-test-profile/**)",
      "Write(./.edge-test-profile/**)",
      "Write(//root/.claude/**)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(doas:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./)",
      "Bash(rm -rf /home)",
      "Bash(rm -rf /home/*)",
      "Bash(rm -rf /home/user)",
      "Bash(rm -rf /etc:*)",
      "Bash(rm -rf /var:*)",
      "Bash(rm -rf /usr:*)",
      "Bash(rm -rf /tmp)",
      "Bash(rm -rf /root:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(chown:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(mkfs.*:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(eval:*)",
      "Bash(exec:*)",
      "Bash(history -c)",
      "Bash(history -w)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease origin main:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push --mirror:*)",
      "Bash(git push --delete:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fx:*)",
      "Bash(git clean -ffd:*)",
      "Bash(git config --global:*)",
      "Bash(git config --system:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref -d:*)",
      "Bash(npm publish:*)",
      "Bash(npm login:*)",
      "Bash(npm adduser:*)",
      "Bash(npm token:*)",
      "Bash(curl:* | sh)",
      "Bash(curl:* | bash)",
      "Bash(curl:* | sudo:*)",
      "Bash(wget:* | sh)",
      "Bash(wget:* | bash)",
      "Bash(curl -fsSL:* | sh)",
      "Bash(curl -fsSL:* | bash)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(telnet:*)",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/bash-guard.sh" }
        ]
      },
      {
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/sensitive-file-guard.sh" }
        ]
      }
    ]
  }
}
