{
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "Bash(mkdir *)",
      "Bash(New-Item *)",
      "Bash(flutter *)",
      "Bash(dart *)",
      "PowerShell(New-Item *)",
      "PowerShell(flutter *)",
      "PowerShell(dart *)",
      "Bash(git -C * status)",
      "Bash(git -C * status *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * log *)",
      "Bash(git -C * branch *)",
      "Bash(git -C * show *)",
      "Bash(git -C * add *)",
      "Bash(git -C * commit *)",
      "Bash(git -C * push *)",
      "Bash(git -C * stash *)",
      "Bash(git -C * remote *)",
      "Bash(git -C * checkout *)",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/second-brain-recall.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "license_and_download_stock|purchase|checkout|subscribe|billing|payment",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/accounting-guard.sh"
          }
        ]
      }
    ]
  }
}
